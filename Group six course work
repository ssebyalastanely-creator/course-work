/**
 * BankAccountFormGUI.java
 *
 * This is the main window (JFrame) for the First Bank Uganda New Account
 * Opening Application Form. It is built with plain Java Swing.
 *
 * The class is organised into clearly-named sections so it is easy to
 * follow even though there are a lot of fields on the form:
 *   1) Field declarations (every text box, combo box, and error label)
 *   2) Constructor + buildXxxPanel() methods that lay out the screen
 *   3) updateDayComboBox() - keeps the Day combo box correct for leap years
 *   4) validateForm() - checks every rule from the coursework
 *   5) handleSubmit() / handleReset() - what happens when buttons are clicked
 */
public class BankAccountFormGUI extends JFrame {

    // ---------- Personal detail fields ----------
    private JTextField firstNameField = new JTextField(18);
    private JTextField lastNameField = new JTextField(18);
    private JTextField ninField = new JTextField(18);
    private JTextField emailField = new JTextField(18);
    private JTextField confirmEmailField = new JTextField(18);
    private JTextField phoneField = new JTextField(18);
    private JPasswordField pinField = new JPasswordField(18);
    private JPasswordField confirmPinField = new JPasswordField(18);

    // ---------- Date of birth combo boxes ----------
    private JComboBox<Integer> yearCombo;
    private JComboBox<String> monthCombo;
    private JComboBox<Integer> dayCombo;
    private static final String[] MONTH_NAMES = {
        "January", "February", "March", "April", "May", "June",
        "July", "August", "September", "October", "November", "December"
    };

    // ---------- Account type / branch / deposit ----------
    private JComboBox<String> accountTypeCombo;
    private JComboBox<String> branchCombo;
    private JTextField depositField = new JTextField(18);

    // ---------- Joint-account-only field ----------
    private JTextField secondNinField = new JTextField(18);

    // ---------- Inline error labels (one red label per field) ----------
    private JLabel firstNameError = makeErrorLabel();
    private JLabel lastNameError = makeErrorLabel();
    private JLabel ninError = makeErrorLabel();
    private JLabel emailError = makeErrorLabel();
    private JLabel confirmEmailError = makeErrorLabel();
    private JLabel phoneError = makeErrorLabel();
    private JLabel pinError = makeErrorLabel();
    private JLabel confirmPinError = makeErrorLabel();
    private JLabel dobError = makeErrorLabel();
    private JLabel accountTypeError = makeErrorLabel();
    private JLabel branchError = makeErrorLabel();
    private JLabel depositError = makeErrorLabel();
    private JLabel secondNinError = makeErrorLabel();

    // ---------- Buttons + read-only summary area ----------
    private JButton submitButton = new JButton("Submit");
    private JButton resetButton = new JButton("Reset");
    private JTextArea summaryArea = new JTextArea(4, 50);

    // ---------- Helper objects ----------
    private DatabaseManager databaseManager = new DatabaseManager();

    private static final String SELECT_PLACEHOLDER = "-- Select --";
    private static final String[] ACCOUNT_TYPES = {"Savings", "Current", "Fixed Deposit", "Student", "Joint"};
    private static final String[] BRANCHES = {"Kampala", "Gulu", "Mbarara", "Jinja", "Mbale"};

    /** Builds a small red, italic label used to show a field-specific error message. */
    private static JLabel makeErrorLabel() {
        JLabel label = new JLabel(" ");
        label.setForeground(Color.RED);
        label.setFont(label.getFont().deriveFont(Font.ITALIC, 11f));
        return label;
    }

    public BankAccountFormGUI() {
        super("First Bank Uganda - New Account Opening Form");

        setLayout(new BorderLayout(10, 10));
        add(buildHeaderPanel(), BorderLayout.NORTH);
        add(new JScrollPane(buildFormPanel()), BorderLayout.CENTER);
        add(buildBottomPanel(), BorderLayout.SOUTH);

        wireListeners();
        updateDayComboBox(); // make sure the Day combo starts correctly populated

        setSize(780, 760);
        setMinimumSize(new Dimension(700, 600));
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setLocationRelativeTo(null); // centre the window on screen
    }

    // -----------------------------------------------------------------
    // 2) LAYOUT BUILDING METHODS
    // -----------------------------------------------------------------

    private JPanel buildHeaderPanel() {
        JPanel header = new JPanel();
        header.setLayout(new BoxLayout(header, BoxLayout.Y_AXIS));
        header.setBorder(BorderFactory.createEmptyBorder(12, 16, 6, 16));

        JLabel bankName = new JLabel("FIRST BANK UGANDA");
        bankName.setFont(new Font("SansSerif", Font.BOLD, 22));
        bankName.setAlignmentX(Component.LEFT_ALIGNMENT);

        JLabel formTitle = new JLabel("New Bank Account Opening Application Form");
        formTitle.setFont(new Font("SansSerif", Font.PLAIN, 14));
        formTitle.setAlignmentX(Component.LEFT_ALIGNMENT);

        header.add(bankName);
        header.add(formTitle);
        return header;
    }

    private JPanel buildFormPanel() {
        JPanel panel = new JPanel(new GridBagLayout());
        panel.setBorder(BorderFactory.createEmptyBorder(10, 16, 10, 16));
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.insets = new Insets(4, 4, 4, 4);
        gbc.anchor = GridBagConstraints.WEST;
        gbc.fill = GridBagConstraints.HORIZONTAL;

        int row = 0;
        row = addRow(panel, gbc, row, "First Name:", firstNameField, firstNameError);
        row = addRow(panel, gbc, row, "Last Name:", lastNameField, lastNameError);
        row = addRow(panel, gbc, row, "National ID (NIN):", ninField, ninError);
        row = addRow(panel, gbc, row, "Email:", emailField, emailError);
        row = addRow(panel, gbc, row, "Confirm Email:", confirmEmailField, confirmEmailError);
        row = addRow(panel, gbc, row, "Phone Number (+256XXXXXXXXX):", phoneField, phoneError);
        row = addRow(panel, gbc, row, "PIN (4-6 digits):", pinField, pinError);
        row = addRow(panel, gbc, row, "Confirm PIN:", confirmPinField, confirmPinError);

        // ---- Date of birth row: three combo boxes side by side ----
        gbc.gridx = 0; gbc.gridy = row; gbc.weightx = 0;
        panel.add(new JLabel("Date of Birth:"), gbc);

        JPanel dobPanel = new JPanel(new FlowLayout(FlowLayout.LEFT, 6, 0));
        int currentYear = java.time.Year.now().getValue();
        Integer[] years = new Integer[currentYear - 1940 + 1];
        for (int i = 0; i < years.length; i++) {
            years[i] = 1940 + i;
        }
        yearCombo = new JComboBox<>(years);
        yearCombo.setSelectedItem(currentYear - 25); // sensible default
        monthCombo = new JComboBox<>(MONTH_NAMES);
        dayCombo = new JComboBox<>();

        dobPanel.add(new JLabel("Year:"));
        dobPanel.add(yearCombo);
        dobPanel.add(new JLabel("Month:"));
        dobPanel.add(monthCombo);
        dobPanel.add(new JLabel("Day:"));
        dobPanel.add(dayCombo);

        gbc.gridx = 1; gbc.weightx = 1;
        panel.add(dobPanel, gbc);
        row++;
        gbc.gridx = 1; gbc.gridy = row; gbc.weightx = 1;
        panel.add(dobError, gbc);
        row++;

        // ---- Account Type ----
        accountTypeCombo = new JComboBox<>();
        accountTypeCombo.addItem(SELECT_PLACEHOLDER);
        for (String type : ACCOUNT_TYPES) {
            accountTypeCombo.addItem(type);
        }
        row = addRow(panel, gbc, row, "Account Type:", accountTypeCombo, accountTypeError);

        // ---- Branch ----
        branchCombo = new JComboBox<>();
        branchCombo.addItem(SELECT_PLACEHOLDER);
        for (String branch : BRANCHES) {
            branchCombo.addItem(branch);
        }
        row = addRow(panel, gbc, row, "Branch:", branchCombo, branchError);

        // ---- Opening deposit ----
        row = addRow(panel, gbc, row, "Opening Deposit (UGX):", depositField, depositError);

        // ---- Second NIN (Joint accounts only) ----
        row = addRow(panel, gbc, row, "Second Applicant NIN (Joint accounts only):", secondNinField, secondNinError);

        return panel;
    }

    /** Adds one "Label | Field" row, plus the matching error label directly underneath, to the form panel. */
    private int addRow(JPanel panel, GridBagConstraints gbc, int row, String labelText,
                        JComponent field, JLabel errorLabel) {
        gbc.gridx = 0; gbc.gridy = row; gbc.weightx = 0;
        panel.add(new JLabel(labelText), gbc);

        gbc.gridx = 1; gbc.weightx = 1;
        panel.add(field, gbc);
        row++;

        gbc.gridx = 1; gbc.gridy = row; gbc.weightx = 1;
        panel.add(errorLabel, gbc);
        row++;

        return row;
    }

    private JPanel buildBottomPanel() {
        JPanel bottom = new JPanel(new BorderLayout(8, 8));
        bottom.setBorder(BorderFactory.createEmptyBorder(0, 16, 12, 16));

        JPanel buttonPanel = new JPanel(new FlowLayout(FlowLayout.LEFT));
        buttonPanel.add(submitButton);
        buttonPanel.add(resetButton);

        JPanel summaryPanel = new JPanel(new BorderLayout(4, 4));
        summaryPanel.add(new JLabel("Account Summary is Below:"), BorderLayout.NORTH);
        summaryArea.setEditable(false);
        summaryArea.setLineWrap(true);
        summaryArea.setWrapStyleWord(true);
        summaryArea.setBackground(new Color(245, 245, 245));
        summaryPanel.add(new JScrollPane(summaryArea), BorderLayout.CENTER);

        bottom.add(buttonPanel, BorderLayout.NORTH);
        bottom.add(summaryPanel, BorderLayout.CENTER);
        return bottom;
    }

    // -----------------------------------------------------------------
    // 3) LISTENERS
    // -----------------------------------------------------------------

    private void wireListeners() {
        // Whenever Year or Month changes, the number of valid Days can change
        // (28/29/30/31), so we rebuild the Day combo box every time.
        ActionListener dobChangedListener = new ActionListener() {
            @Override
            public void actionPerformed(ActionEvent e) {
                updateDayComboBox();
            }
        };
        yearCombo.addActionListener(dobChangedListener);
        monthCombo.addActionListener(dobChangedListener);

        submitButton.addActionListener(new ActionListener() {
            @Override
            public void actionPerformed(ActionEvent e) {
                handleSubmit();
            }
        });

        resetButton.addActionListener(new ActionListener() {
            @Override
            public void actionPerformed(ActionEvent e) {
                handleReset();
            }
        });
    }

    /** Rebuilds the Day combo box so it always has the correct number of days for the chosen Year/Month. */
    private void updateDayComboBox() {
        int year = (Integer) yearCombo.getSelectedItem();
        int month = monthCombo.getSelectedIndex() + 1; // combo index 0 = January = month 1

        Integer previouslySelectedDay = (Integer) dayCombo.getSelectedItem();
        int maxDay = ValidationUtils.daysInMonth(year, month);

        dayCombo.removeAllItems();
        for (int d = 1; d <= maxDay; d++) {
            dayCombo.addItem(d);
        }

        // Try to keep the same day selected if it is still valid (e.g. switching
        // from March 31 to April should fall back to April 30, not crash).
        if (previouslySelectedDay != null && previouslySelectedDay <= maxDay) {
            dayCombo.setSelectedItem(previouslySelectedDay);
        }
    }

    // -----------------------------------------------------------------
    // 4) VALIDATION
    // -----------------------------------------------------------------

    /**
     * Checks every field against the rules in the coursework. Any problems
     * found are (a) written into the matching red inline error label and
     * (b) added to the returned list, which is used for the pop-up summary
     * dialog. An empty returned list means the form is fully valid.
     */
    private List<String> validateForm(Account accountBeingChecked, String accountType,
                                       double deposit, boolean depositParsedOk) {
        List<String> problems = new ArrayList<>();

        String firstName = firstNameField.getText().trim();
        String lastName = lastNameField.getText().trim();
        String nin = ninField.getText().trim().toUpperCase();
        String email = emailField.getText().trim();
        String confirmEmail = confirmEmailField.getText().trim();
        String phone = phoneField.getText().trim();
        String pin = new String(pinField.getPassword()).trim();
        String confirmPin = new String(confirmPinField.getPassword()).trim();
        String secondNin = secondNinField.getText().trim().toUpperCase();

        if (!ValidationUtils.isValidName(firstName)) {
            setError(firstNameError, "Letters only, 2-30 characters.");
            problems.add("First Name: letters only, 2-30 characters.");
        }
        if (!ValidationUtils.isValidName(lastName)) {
            setError(lastNameError, "Letters only, 2-30 characters.");
            problems.add("Last Name: letters only, 2-30 characters.");
        }
        if (!ValidationUtils.isValidNin(nin)) {
            setError(ninError, "Must be exactly 14 uppercase alphanumeric characters.");
            problems.add("National ID (NIN): must be exactly 14 uppercase alphanumeric characters.");
        }
        if (!ValidationUtils.isValidEmail(email)) {
            setError(emailError, "Enter a valid email address.");
            problems.add("Email: not a valid email address.");
        } else if (!ValidationUtils.emailsMatch(email, confirmEmail)) {
            setError(confirmEmailError, "Does not match Email.");
            problems.add("Confirm Email: does not match Email.");
        }
        if (!ValidationUtils.isValidPhone(phone)) {
            setError(phoneError, "Format must be +256XXXXXXXXX.");
            problems.add("Phone Number: must follow the format +256XXXXXXXXX.");
        }
        if (!ValidationUtils.isValidPin(pin)) {
            setError(pinError, "4-6 digits, not all identical (e.g. 0000).");
            problems.add("PIN: must be 4-6 digits and not all identical digits.");
        } else if (!ValidationUtils.pinsMatch(pin, confirmPin)) {
            setError(confirmPinError, "Does not match PIN.");
            problems.add("Confirm PIN: does not match PIN.");
        }

        // ---- Age (derived from Date of Birth) ----
        int dobYear = (Integer) yearCombo.getSelectedItem();
        int dobMonth = monthCombo.getSelectedIndex() + 1;
        int dobDay = (Integer) dayCombo.getSelectedItem();
        int age = ValidationUtils.calculateAge(dobYear, dobMonth, dobDay);

        if (!ValidationUtils.isValidGeneralAge(age)) {
            setError(dobError, "Applicant age must be 18-75 (current age: " + age + ").");
            problems.add("Date of Birth: applicant age must be 18-75 (current age: " + age + ").");
        } else if (accountType.equals("Student") && !ValidationUtils.isValidStudentAge(age)) {
            setError(dobError, "Student accounts require age 18-25 (current age: " + age + ").");
            problems.add("Date of Birth: Student accounts require applicant age 18-25 (current age: " + age + ").");
        }

        // ---- Account Type ----
        if (accountType.equals(SELECT_PLACEHOLDER)) {
            setError(accountTypeError, "Please select an account type.");
            problems.add("Account Type: please select exactly one account type.");
        }

        // ---- Branch ----
        String branch = (String) branchCombo.getSelectedItem();
        if (branch.equals(SELECT_PLACEHOLDER)) {
            setError(branchError, "Please select a branch.");
            problems.add("Branch: please select exactly one branch.");
        }

        // ---- Opening Deposit (this is the polymorphic check) ----
        if (!depositParsedOk) {
            setError(depositError, "Enter a valid numeric amount.");
            problems.add("Opening Deposit: must be a valid number.");
        } else if (accountBeingChecked != null) {
            // accountBeingChecked.minimumDeposit() calls the OVERRIDDEN version
            // for whichever subclass (Savings/Current/.../Joint) was selected.
            // This is the polymorphism the coursework specifically asks for.
            double minimumRequired = accountBeingChecked.minimumDeposit();
            if (!ValidationUtils.isValidDeposit(deposit, minimumRequired)) {
                String msg = String.format("Minimum for %s accounts is UGX %,.0f.",
                        accountBeingChecked.getAccountTypeName(), minimumRequired);
                setError(depositError, msg);
                problems.add("Opening Deposit: " + msg);
            }
        }

        // ---- Second NIN (only required for Joint accounts) ----
        if (accountType.equals("Joint")) {
            if (!ValidationUtils.isValidNin(secondNin)) {
                setError(secondNinError, "Joint accounts require a valid 14-character second NIN.");
                problems.add("Second Applicant NIN: required for Joint accounts, must be 14 uppercase alphanumeric characters.");
            } else if (secondNin.equals(nin)) {
                setError(secondNinError, "Second NIN must be different from the applicant's own NIN.");
                problems.add("Second Applicant NIN: must be different from the applicant's own NIN.");
            }
        }

        return problems;
    }

    private void setError(JLabel label, String message) {
        label.setText(message);
    }

    private void clearAllErrors() {
        JLabel[] allErrorLabels = {
            firstNameError, lastNameError, ninError, emailError, confirmEmailError,
            phoneError, pinError, confirmPinError, dobError, accountTypeError,
            branchError, depositError, secondNinError
        };
        for (JLabel label : allErrorLabels) {
            label.setText(" ");
        }
    }

    // -----------------------------------------------------------------
    // 5) BUTTON ACTIONS
    // -----------------------------------------------------------------

    private void handleSubmit() {
        clearAllErrors();

        String accountType = (String) accountTypeCombo.getSelectedItem();
        String branch = (String) branchCombo.getSelectedItem();

        // Parse the opening deposit safely.
        double deposit = 0.0;
        boolean depositParsedOk = true;
        try {
            deposit = Double.parseDouble(depositField.getText().trim());
            if (deposit < 0) {
                depositParsedOk = false;
            }
        } catch (NumberFormatException e) {
            depositParsedOk = false;
        }

        int dobYear = (Integer) yearCombo.getSelectedItem();
        int dobMonth = monthCombo.getSelectedIndex() + 1;
        int dobDay = (Integer) dayCombo.getSelectedItem();

        // Build an Account object EARLY, using the AccountFactory, as long as a
        // real account type was chosen. We build it before validation finishes
        // so that validateForm() can call its overridden minimumDeposit() and
        // get the correct, type-specific minimum - that is the polymorphism
        // requirement from the coursework in action.
        Account account = null;
        if (!accountType.equals(SELECT_PLACEHOLDER)) {
            account = AccountFactory.createAccount(
                    accountType,
                    firstNameField.getText().trim(),
                    lastNameField.getText().trim(),
                    ninField.getText().trim().toUpperCase(),
                    emailField.getText().trim(),
                    phoneField.getText().trim(),
                    new String(pinField.getPassword()).trim(),
                    dobYear, dobMonth, dobDay,
                    branch,
                    deposit,
                    secondNinField.getText().trim().toUpperCase()
            );
        }

        List<String> problems = validateForm(account, accountType, deposit, depositParsedOk);

        if (!problems.isEmpty()) {
            StringBuilder message = new StringBuilder("Please fix the following problems:\n\n");
            for (String problem : problems) {
                message.append("- ").append(problem).append("\n");
            }
            JOptionPane.showMessageDialog(this, message.toString(),
                    "Form has errors", JOptionPane.ERROR_MESSAGE);
            return;
        }

        // ---- Everything is valid: generate the account number and save ----
        String accountNumber = AccountNumberGenerator.generateNextAccountNumber(branch);
        account.setAccountNumber(accountNumber);

        String summaryText = account.getFormattedSummary();

        // Try to persist the record into the MS Access database. If the
        // UCanAccess driver has not been set up yet, we still show the
        // summary on screen (so the form remains useful for testing/marking)
        // but we warn the user that the database save did not happen.
        try {
            databaseManager.insertAccount(account);
            summaryArea.setText(summaryText);
            summaryArea.setCaretPosition(0); // make sure the summary line is visible, not scrolled away
            JOptionPane.showMessageDialog(this,
                    "Account created and saved to the database successfully.",
                    "Success", JOptionPane.INFORMATION_MESSAGE);
        } catch (SQLException e) {
            summaryArea.setText(summaryText + "\n\n[NOTE: Could not save to the Access database - "
                    + e.getMessage() + "]");
            summaryArea.setCaretPosition(0); // make sure the summary line is visible, not scrolled away
            JOptionPane.showMessageDialog(this,
                    "Account summary was created, but saving to the Access database failed:\n"
                  + e.getMessage()
                  + "\n\nSee the setup documentation for installing the UCanAccess driver.",
                    "Database Warning", JOptionPane.WARNING_MESSAGE);
        }
    }

    private void handleReset() {
        firstNameField.setText("");
        lastNameField.setText("");
        ninField.setText("");
        emailField.setText("");
        confirmEmailField.setText("");
        phoneField.setText("");
        pinField.setText("");
        confirmPinField.setText("");
        depositField.setText("");
        secondNinField.setText("");

        accountTypeCombo.setSelectedIndex(0);
        branchCombo.setSelectedIndex(0);
        yearCombo.setSelectedItem(java.time.Year.now().getValue() - 25);
        monthCombo.setSelectedIndex(0);
        updateDayComboBox();
        dayCombo.setSelectedIndex(0);

        clearAllErrors();
        summaryArea.setText("");
    }
}

/**
 * CurrentAccount.java
 *
 * Concrete subclass of Account.
 * Rule from the coursework table: minimum deposit UGX 200,000.
 * Special rule: Overdraft allowed, no interest.
 */
public class CurrentAccount extends Account {

    public CurrentAccount(String firstName, String lastName, String nin, String email,
                           String phoneNumber, String pin, int dobYear, int dobMonth, int dobDay,
                           String branch, double openingDeposit) {
        super(firstName, lastName, nin, email, phoneNumber, pin, dobYear, dobMonth, dobDay, branch, openingDeposit);
    }

    @Override
    public double minimumDeposit() {
        return 200000.0;
    }

    @Override
    public String getAccountTypeName() {
        return "Current";
    }

    @Override
    public String getSpecialRule() {
        return "Overdraft allowed, no interest";
    }
}
