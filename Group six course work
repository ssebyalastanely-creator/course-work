import java.sql.Connection;
import java.sql.DatabaseMetaData;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.sql.SQLException;
import java.sql.Statement;
import java.io.File;

/**
 * DatabaseManager.java
 *
 * Handles saving every successfully-submitted account into a Microsoft
 * Access database file (BankAccounts.accdb), as required by the
 * coursework ("append the record to the MS. Access database").
 *
 * IMPORTANT - PLEASE READ (also explained in the setup documentation):
 * Plain Java cannot talk to a .accdb file by itself - there is no
 * official, free, cross-platform Access driver from Microsoft. The
 * normal/expected way to do this from Java is the free, open-source
 * "UCanAccess" JDBC driver. This class is written using only standard
 * java.sql classes (Connection, PreparedStatement, etc.), so it COMPILES
 * fine with nothing extra. To actually RUN it, you must download the
 * UCanAccess jar files once and put them on the classpath - full,
 * step-by-step instructions are in README.md / the Word documentation.
 *
 * If, for some reason, the UCanAccess driver/jars are missing, the
 * connect() method will throw a SQLException. The GUI catches that
 * exception so the rest of the application still works (you can still
 * fill the form, validate it, and see the on-screen summary) - it just
 * will not be able to write the record into the .accdb file until the
 * driver is set up correctly.
 */
public class DatabaseManager {

    // The Access database file will be created automatically the first
    // time the program runs, right next to the compiled program.
    private static final String DB_FILE_NAME = "BankAccounts.accdb";

    /**
     * Opens (and, the very first time, creates) the Access database file,
     * then opens a JDBC connection to it using the UCanAccess driver.
     */
    private Connection connect() throws SQLException {
        try {
            // Loading the driver class explicitly is good practice, even
            // though most modern JDBC drivers also register themselves
            // automatically.
            Class.forName("net.ucanaccess.jdbc.UcanaccessDriver");
        } catch (ClassNotFoundException e) {
            throw new SQLException(
                "UCanAccess driver was not found on the classpath.\n"
              + "Please follow the database setup steps in the documentation "
              + "(download the UCanAccess jars and add them to the classpath).", e);
        }

        File dbFile = new File(DB_FILE_NAME);
        String url;
        if (dbFile.exists()) {
            // Database already exists - just connect to it.
            url = "jdbc:ucanaccess://" + dbFile.getAbsolutePath();
        } else {
            // Database does not exist yet - ask UCanAccess to create a
            // brand new, empty Access 2010-format database file for us.
            url = "jdbc:ucanaccess://" + dbFile.getAbsolutePath() + ";newdatabaseversion=V2010";
        }

        return DriverManager.getConnection(url);
    }

    /**
     * Makes sure the "Accounts" table exists in the database. If this is
     * the very first time the program has run, the table will not exist
     * yet, so we create it here.
     */
    private void ensureTableExists(Connection conn) throws SQLException {
        DatabaseMetaData metaData = conn.getMetaData();
        try (ResultSet tables = metaData.getTables(null, null, "Accounts", null)) {
            if (tables.next()) {
                return; // table already exists - nothing to do
            }
        }

        String createTableSql =
                "CREATE TABLE Accounts (" +
                "AccountNumber TEXT(20), " +
                "FirstName TEXT(30), " +
                "LastName TEXT(30), " +
                "NIN TEXT(14), " +
                "Email TEXT(60), " +
                "PhoneNumber TEXT(15), " +
                "DateOfBirth TEXT(10), " +
                "AccountType TEXT(20), " +
                "Branch TEXT(20), " +
                "OpeningDeposit DOUBLE, " +
                "SecondHolderNIN TEXT(14), " +
                "DateCreated TEXT(19)" +
                ")";

        try (Statement statement = conn.createStatement()) {
            statement.execute(createTableSql);
        }
    }

    /**
     * Saves one account record into the Accounts table.
     * Returns true if the save succeeded.
     * Throws SQLException if the driver is missing or the save fails -
     * the caller (the GUI) decides how to inform the user.
     */
    public boolean insertAccount(Account account) throws SQLException {
        try (Connection conn = connect()) {
            ensureTableExists(conn);

            String insertSql =
                    "INSERT INTO Accounts (AccountNumber, FirstName, LastName, NIN, Email, " +
                    "PhoneNumber, DateOfBirth, AccountType, Branch, OpeningDeposit, " +
                    "SecondHolderNIN, DateCreated) VALUES (?,?,?,?,?,?,?,?,?,?,?,?)";

            try (PreparedStatement ps = conn.prepareStatement(insertSql)) {
                ps.setString(1, account.getAccountNumber());
                ps.setString(2, account.getFirstName());
                ps.setString(3, account.getLastName());
                ps.setString(4, account.getNin());
                ps.setString(5, account.getEmail());
                ps.setString(6, account.getPhoneNumber());
                ps.setString(7, account.getDobAsText());
                ps.setString(8, account.getAccountTypeName());
                ps.setString(9, account.getBranch());
                ps.setDouble(10, account.getOpeningDeposit());

                // Only JointAccount objects have a second NIN; everything
                // else stores an empty value. instanceof + a cast is the
                // simplest beginner-friendly way to reach the extra field
                // that only exists on the JointAccount subclass.
                String secondNin = "";
                if (account instanceof JointAccount) {
                    JointAccount joint = (JointAccount) account;
                    secondNin = joint.getSecondHolderNin();
                }
                ps.setString(11, secondNin);

                ps.setString(12, java.time.LocalDateTime.now().toString());

                ps.executeUpdate();
            }
        }
        return true;
    }
}

