import java.time.LocalDate;
import java.util.regex.Pattern;

/**
 * ValidationUtils.java
 *
 * Every validation rule from section (c) of the coursework lives in this
 * one class as a small static method. Keeping them all here (instead of
 * scattering checks throughout the GUI code) makes the rules easy to find,
 * easy to test, and easy to mark against the coursework table.
 *
 * Each "isValidXxx" method returns true/false. The GUI class is in charge
 * of deciding WHAT MESSAGE to show when a method returns false - this
 * class only decides PASS or FAIL.
 */
public class ValidationUtils {

    // Pre-built regular expressions (compiled once, reused many times).
    private static final Pattern NAME_PATTERN = Pattern.compile("^[A-Za-z]{2,30}$");
    private static final Pattern NIN_PATTERN = Pattern.compile("^[A-Z0-9]{14}$");
    private static final Pattern EMAIL_PATTERN =
            Pattern.compile("^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$");
    // NOTE on phone format: the coursework gives the example +256772123456.
    // Counting the digits AFTER the +256 country code in that example gives
    // 9 digits (772123456), for 12 digits in total once you include "256".
    // We validate against that worked example: +256 followed by 9 digits.
    private static final Pattern PHONE_PATTERN = Pattern.compile("^\\+256\\d{9}$");
    private static final Pattern PIN_PATTERN = Pattern.compile("^\\d{4,6}$");

    /** First/Last name: required, trimmed, letters only, 2-30 characters. */
    public static boolean isValidName(String name) {
        if (name == null) return false;
        return NAME_PATTERN.matcher(name.trim()).matches();
    }

    /** National ID: exactly 14 alphanumeric characters, must be UPPERCASE. */
    public static boolean isValidNin(String nin) {
        if (nin == null) return false;
        return NIN_PATTERN.matcher(nin.trim()).matches();
    }

    /** Basic but solid email format check. */
    public static boolean isValidEmail(String email) {
        if (email == null) return false;
        return EMAIL_PATTERN.matcher(email.trim()).matches();
    }

    /** Email and its confirmation field must match exactly. */
    public static boolean emailsMatch(String email, String confirmEmail) {
        if (email == null || confirmEmail == null) return false;
        return email.trim().equals(confirmEmail.trim());
    }

    /** Ugandan phone format: +256XXXXXXXXX. */
    public static boolean isValidPhone(String phone) {
        if (phone == null) return false;
        return PHONE_PATTERN.matcher(phone.trim()).matches();
    }

    /** PIN: numeric only, 4-6 digits, and not every digit the same (e.g. 0000, 11111). */
    public static boolean isValidPin(String pin) {
        if (pin == null) return false;
        String trimmed = pin.trim();
        if (!PIN_PATTERN.matcher(trimmed).matches()) {
            return false;
        }
        return !isAllSameDigit(trimmed);
    }

    /** PIN and Confirm PIN must match exactly. */
    public static boolean pinsMatch(String pin, String confirmPin) {
        if (pin == null || confirmPin == null) return false;
        return pin.trim().equals(confirmPin.trim());
    }

    /** Helper: checks if every character in the PIN string is the same digit. */
    private static boolean isAllSameDigit(String pin) {
        char first = pin.charAt(0);
        for (int i = 1; i < pin.length(); i++) {
            if (pin.charAt(i) != first) {
                return false;
            }
        }
        return true;
    }

    /** Opening deposit must be a positive number that meets or exceeds the minimum. */
    public static boolean isValidDeposit(double deposit, double minimumRequired) {
        return deposit >= minimumRequired;
    }

    // ---------------------------------------------------------------
    // Date of birth / age helpers
    // ---------------------------------------------------------------

    /** Standard leap-year rule: divisible by 4, except centuries unless also divisible by 400. */
    public static boolean isLeapYear(int year) {
        return (year % 4 == 0 && year % 100 != 0) || (year % 400 == 0);
    }

    /**
     * Returns how many days the given month has, taking leap years into
     * account for February. month is 1-12 (1 = January).
     */
    public static int daysInMonth(int year, int month) {
        int[] daysPerMonth = {31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31};
        if (month == 2 && isLeapYear(year)) {
            return 29;
        }
        return daysPerMonth[month - 1];
    }

    /**
     * Calculates the applicant's age in completed years as of today,
     * based on their date of birth.
     */
    public static int calculateAge(int dobYear, int dobMonth, int dobDay) {
        LocalDate dob = LocalDate.of(dobYear, dobMonth, dobDay);
        LocalDate today = LocalDate.now();
        int age = today.getYear() - dob.getYear();
        // If the birthday has not happened yet this year, subtract one.
        if (today.getMonthValue() < dob.getMonthValue()
                || (today.getMonthValue() == dob.getMonthValue() && today.getDayOfMonth() < dob.getDayOfMonth())) {
            age--;
        }
        return age;
    }

    /** General account age rule: must be 18-75 inclusive. */
    public static boolean isValidGeneralAge(int age) {
        return age >= 18 && age <= 75;
    }

    /** Extra Student account rule: must be 18-25 inclusive. */
    public static boolean isValidStudentAge(int age) {
        return age >= 18 && age <= 25;
    }
}

/**
 * Account.java
 *
 * This is the ABSTRACT base class for every type of bank account in the
 * First Bank Uganda system. It is "abstract" because we never create a
 * plain Account by itself - we always create one of its concrete child
 * classes (SavingsAccount, CurrentAccount, FixedDepositAccount,
 * StudentAccount, JointAccount).
 *
 * The class stores all the fields that EVERY account type needs
 * (name, NIN, email, phone, PIN, date of birth, branch, deposit, account
 * number). Each child class then adds its own special rule by overriding
 * the abstract method minimumDeposit().
 *
 * This is the "polymorphism" the coursework asks for: the form code will
 * hold a variable of type Account, but depending on which subclass was
 * actually created, calling account.minimumDeposit() will automatically
 * run the correct version for that account type.
 */
public abstract class Account {

    // ---- Fields shared by every account type ----
    protected String accountNumber;   // e.g. KLA-2026-000142 (generated, not typed by the user)
    protected String firstName;
    protected String lastName;
    protected String nin;             // National ID Number (14 characters)
    protected String email;
    protected String phoneNumber;     // Format: +256XXXXXXXXX
    protected String pin;             // 4-6 digit PIN (stored as text for simplicity)
    protected int dobYear;
    protected int dobMonth;           // 1 = January ... 12 = December
    protected int dobDay;
    protected String branch;          // Kampala, Gulu, Mbarara, Jinja, Mbale
    protected double openingDeposit;

    /**
     * Simple constructor. We pass in everything the form collected.
     * The accountNumber is NOT set here - it is generated later, only
     * after the form confirms every field passed validation.
     */
    public Account(String firstName, String lastName, String nin, String email,
                    String phoneNumber, String pin, int dobYear, int dobMonth, int dobDay,
                    String branch, double openingDeposit) {
        this.firstName = firstName;
        this.lastName = lastName;
        this.nin = nin;
        this.email = email;
        this.phoneNumber = phoneNumber;
        this.pin = pin;
        this.dobYear = dobYear;
        this.dobMonth = dobMonth;
        this.dobDay = dobDay;
        this.branch = branch;
        this.openingDeposit = openingDeposit;
    }

    // ---- ABSTRACT METHODS ----
    // Every child class MUST provide its own version of these two methods.
    // This is where the "Minimum Opening Deposit by Account Type" table
    // from the coursework becomes real code.

    /** @return the minimum opening deposit (in UGX) required for this account type. */
    public abstract double minimumDeposit();

    /** @return a friendly name for this account type, e.g. "Savings". */
    public abstract String getAccountTypeName();

    /** @return a short description of the special rule for this account type. */
    public abstract String getSpecialRule();

    // ---- Plain getters and setters (no advanced logic, just storage) ----

    public String getAccountNumber() { return accountNumber; }
    public void setAccountNumber(String accountNumber) { this.accountNumber = accountNumber; }

    public String getFirstName() { return firstName; }
    public String getLastName() { return lastName; }
    public String getNin() { return nin; }
    public String getEmail() { return email; }
    public String getPhoneNumber() { return phoneNumber; }
    public String getPin() { return pin; }
    public int getDobYear() { return dobYear; }
    public int getDobMonth() { return dobMonth; }
    public int getDobDay() { return dobDay; }
    public String getBranch() { return branch; }
    public double getOpeningDeposit() { return openingDeposit; }

    /**
     * Builds the Date of Birth as a simple "YYYY-MM-DD" text string,
     * zero-padding the month and day so it always looks like 2004-02-29.
     */
    public String getDobAsText() {
        return String.format("%04d-%02d-%02d", dobYear, dobMonth, dobDay);
    }

    /**
     * Builds the exact "Account Summary" line shown in the coursework example:
     * ACC: KLA-2026-000142 | Okello Allan | Savings | Kampala | DOB 2004-02-29 |
     * +256772123456 | Deposit 50,000 | okello.allan@firstbank.co.ug
     */
    public String getFormattedSummary() {
        // We use a NumberFormat-style comma grouping for the deposit amount.
        String depositText = String.format("%,.0f", openingDeposit);

        return "ACC: " + accountNumber
                + " | " + firstName + " " + lastName
                + " | " + getAccountTypeName()
                + " | " + branch
                + " | DOB " + getDobAsText()
                + " | " + phoneNumber
                + " | Deposit " + depositText
                + " | " + email;
    }
}

/**
 * AccountFactory.java
 *
 * A small helper class with one job: look at the Account Type the user
 * picked in the combo box (a plain String like "Savings" or "Joint") and
 * build the matching Account subclass object.
 *
 * This is the piece that makes the polymorphism in the coursework
 * actually happen. After this method runs, the rest of the program
 * (validation, the database, the summary text) only ever talks to the
 * variable through its parent type "Account" - but Java will still run
 * the correct overridden method (e.g. minimumDeposit()) for whichever
 * real subclass was created here.
 */
public class AccountFactory {

    /**
     * Creates the correct Account subclass for the given account type.
     *
     * @param accountType     one of: Savings, Current, Fixed Deposit, Student, Joint
     * @param secondHolderNin only used when accountType is "Joint"; pass null/"" otherwise
     */
    public static Account createAccount(String accountType,
                                         String firstName, String lastName, String nin,
                                         String email, String phoneNumber, String pin,
                                         int dobYear, int dobMonth, int dobDay,
                                         String branch, double openingDeposit,
                                         String secondHolderNin) {

        if (accountType.equals("Savings")) {
            return new SavingsAccount(firstName, lastName, nin, email, phoneNumber, pin,
                    dobYear, dobMonth, dobDay, branch, openingDeposit);

        } else if (accountType.equals("Current")) {
            return new CurrentAccount(firstName, lastName, nin, email, phoneNumber, pin,
                    dobYear, dobMonth, dobDay, branch, openingDeposit);

        } else if (accountType.equals("Fixed Deposit")) {
            return new FixedDepositAccount(firstName, lastName, nin, email, phoneNumber, pin,
                    dobYear, dobMonth, dobDay, branch, openingDeposit);

        } else if (accountType.equals("Student")) {
            return new StudentAccount(firstName, lastName, nin, email, phoneNumber, pin,
                    dobYear, dobMonth, dobDay, branch, openingDeposit);

        } else if (accountType.equals("Joint")) {
            return new JointAccount(firstName, lastName, nin, email, phoneNumber, pin,
                    dobYear, dobMonth, dobDay, branch, openingDeposit, secondHolderNin);

        } else {
            // This should never happen because the combo box only offers
            // the five valid options, but we guard against it anyway.
            throw new IllegalArgumentException("Unknown account type: " + accountType);
        }
    }
}

import java.io.File;
import java.io.FileInputStream;
import java.io.FileOutputStream;
import java.io.IOException;
import java.time.Year;
import java.util.Properties;

/**
 * AccountNumberGenerator.java
 *
 * Builds account numbers in the format required by the coursework:
 *      BRANCHCODE-YYYY-xxxxxx
 * e.g. KLA-2026-000142
 *
 * The counter is "per-year, per-branch", meaning Kampala and Gulu each
 * keep their own separate count, and the count restarts at the start of
 * a new year. To make the counter survive between runs of the program
 * (so account numbers keep incrementing instead of resetting every time
 * you start the app), the counts are saved in a small text file called
 * "account_counters.properties" sitting next to the program.
 */
public class AccountNumberGenerator {

    private static final String COUNTER_FILE = "account_counters.properties";

    /**
     * Converts a full branch name (as shown in the combo box) into its
     * three-letter branch code used inside the account number.
     */
    public static String branchCodeFor(String branchName) {
        switch (branchName) {
            case "Kampala": return "KLA";
            case "Gulu":    return "GUL";
            case "Mbarara": return "MBR";
            case "Jinja":   return "JIN";
            case "Mbale":   return "MBL";
            default:        return "UNK"; // should not happen - combo box limits choices
        }
    }

    /**
     * Generates the next account number for the given branch, for the
     * current calendar year, and saves the updated counter back to disk.
     */
    public static synchronized String generateNextAccountNumber(String branchName) {
        String branchCode = branchCodeFor(branchName);
        int currentYear = Year.now().getValue();
        String counterKey = branchCode + "_" + currentYear;

        Properties counters = loadCounters();

        int nextSequence = 1;
        String existingValue = counters.getProperty(counterKey);
        if (existingValue != null) {
            try {
                nextSequence = Integer.parseInt(existingValue) + 1;
            } catch (NumberFormatException e) {
                nextSequence = 1; // if the file got corrupted somehow, just start over safely
            }
        }

        counters.setProperty(counterKey, String.valueOf(nextSequence));
        saveCounters(counters);

        // Format the running number as 6 digits, padded with leading zeros (e.g. 000142).
        String paddedSequence = String.format("%06d", nextSequence);

        return branchCode + "-" + currentYear + "-" + paddedSequence;
    }

    /** Reads the counters file from disk. Returns an empty Properties object if it does not exist yet. */
    private static Properties loadCounters() {
        Properties props = new Properties();
        File file = new File(COUNTER_FILE);
        if (file.exists()) {
            try (FileInputStream in = new FileInputStream(file)) {
                props.load(in);
            } catch (IOException e) {
                System.out.println("Warning: could not read " + COUNTER_FILE + " (" + e.getMessage() + ")");
            }
        }
        return props;
    }

    /** Writes the counters back to disk so the next run of the program remembers them. */
    private static void saveCounters(Properties props) {
        try (FileOutputStream out = new FileOutputStream(COUNTER_FILE)) {
            props.store(out, "First Bank Uganda - per-branch, per-year account number counters");
        } catch (IOException e) {
            System.out.println("Warning: could not save " + COUNTER_FILE + " (" + e.getMessage() + ")");
        }
    }
}

